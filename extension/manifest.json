{
  "manifest_version": 3,
  "name": "SignalCheck",
  "version": "0.4.0",
  "description": "Análisis estructural del contenido — SignalCheck Engine",
  "author": "SignalCheck Team",
  "homepage_url": "https://gesignalcheck.com",

  "minimum_chrome_version": "102",

  "action": {
    "default_popup": "popup.html",
    "default_title": "SignalCheck",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "alarms"
  ],

  "host_permissions": [
    "https://gesignalcheck-production-8e78.up.railway.app/*",
    "https://gesignalcheck.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png"
      ],
      "matches": [
        "https://*/*"
      ]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://gesignalcheck-production-8e78.up.railway.app https://gesignalcheck.com"
  }
}